{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://work-agent.dev/schemas/app.schema.json",
  "title": "App Configuration",
  "description": "Global application configuration for Work Agent",
  "type": "object",
  "required": ["region", "defaultModel", "invokeModel", "structureModel"],
  "properties": {
    "region": {
      "type": "string",
      "description": "AWS region for Bedrock (e.g., us-east-1)",
      "pattern": "^[a-z]{2}-[a-z]+-[0-9]{1}$"
    },
    "defaultModel": {
      "type": "string",
      "description": "Default Bedrock model ID",
      "examples": [
        "anthropic.claude-3-5-sonnet-20240620-v1:0",
        "anthropic.claude-3-haiku-20240307-v1:0"
      ]
    },
    "invokeModel": {
      "type": "string",
      "description": "Model for /invoke endpoint tool calling",
      "examples": ["us.amazon.nova-2-lite-v1:0"]
    },
    "structureModel": {
      "type": "string",
      "description": "Model for /invoke endpoint structured output",
      "examples": ["us.amazon.nova-micro-v1:0"]
    },
    "defaultMaxTurns": {
      "type": "number",
      "description": "Default maximum turns for agent conversations",
      "default": 10
    },
    "apiEndpoint": {
      "type": "string",
      "description": "Optional API endpoint override (defaults to http://localhost:3141)"
    },
    "systemPrompt": {
      "type": "string",
      "description": "Global system prompt prepended to all agent instructions"
    },
    "templateVariables": {
      "type": "array",
      "description": "Custom template variables for prompt replacement",
      "items": {
        "type": "object",
        "required": ["key", "type"],
        "properties": {
          "key": {
            "type": "string",
            "description": "Variable name (used as {{key}})"
          },
          "type": {
            "type": "string",
            "enum": ["static", "date", "time", "datetime", "custom"],
            "description": "Variable type"
          },
          "value": {
            "type": "string",
            "description": "Static value or custom value"
          },
          "format": {
            "type": "string",
            "description": "JSON format options for date/time types"
          }
        }
      }
    },
    "meetingNotifications": {
      "type": "object",
      "description": "Meeting notification settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable meeting notifications",
          "default": true
        },
        "thresholds": {
          "type": "array",
          "description": "Minutes before meeting to show notifications",
          "items": {
            "type": "number"
          },
          "default": [30, 10, 1]
        }
      }
    },
    "defaultChatFontSize": {
      "type": "number",
      "description": "Default font size for chat messages in pixels",
      "default": 14,
      "minimum": 10,
      "maximum": 24
    }
  },
  "additionalProperties": false
}
