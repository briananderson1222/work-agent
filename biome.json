{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!!**/dist",
      "!!**/dist-server",
      "!!**/dist-ui",
      "!!**/archive"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": false
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noAssignInExpressions": "warn",
        "useIterableCallbackReturn": "off",
        "noImplicitAnyLet": "warn"
      },
      "complexity": {
        "noForEach": "off",
        "noImportantStyles": "off",
        "noBannedTypes": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "off",
        "noDescendingSpecificity": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noUnusedVariables": "warn",
        "noUnusedPrivateClassMembers": "warn",
        "noUnusedFunctionParameters": "warn",
        "noUnusedImports": "warn",
        "noInvalidUseBeforeDeclaration": "warn",
        "useHookAtTopLevel": "warn",
        "useYield": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
