{
  "name": "demo-workspace",
  "version": "1.0.0",
  "displayName": "Demo Workspace",
  "description": "A demo workspace showing Stallion capabilities \u2014 no external dependencies",
  "entrypoint": "src/index.tsx",
  "capabilities": [
    "chat",
    "navigation"
