# Frontend Configuration
# Override the backend API base URL (defaults to http://localhost:3141)
# VITE_API_BASE=http://localhost:3142

# Backend Configuration  
# Override the server port (defaults to 3141)
# PORT=3142

# AWS Configuration
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
