{
  "name": "@stallion-ai/core",
  "version": "0.1.0",
  "description": "Stallion AI — local-first AI agent system built with VoltAgent and Amazon Bedrock",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/sdk",
    "packages/shared",
    "packages/cli",
    "packages/connect"
  ],
  "scripts": {
    "dev:server": "tsx watch ./src-server/index.ts",
    "dev:ui": "vite dev",
    "dev:desktop": "tauri dev",
    "build:server": "node esbuild.config.mjs",
    "build:ui": "vite build",
    "build:desktop": "npm run build:server && tauri build",
    "build": "npm run build:server && npm run build:ui",
    "start:server": "node dist-server/index.js",
    "start:ui": "npx serve dist-ui",
    "cli": "tsx ./src-server/cli.ts",
    "test": "vitest",
    "test:android": "playwright test --project=android",
    "lint": "biome lint src-server/ src-ui/ packages/",
    "lint:fix": "biome check --fix src-server/ src-ui/ packages/",
    "clean": "rm -rf dist-server dist-ui dist-desktop && cd src-desktop && cargo clean",
    "tauri": "tauri",
    "volt": "volt",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@ai-sdk/amazon-bedrock": "^3.0.0",
    "@aws-sdk/client-bedrock": "^3.922.0",
    "@aws-sdk/client-bedrock-runtime": "^3.935.0",
    "@aws-sdk/client-pricing": "^3.922.0",
    "@aws-sdk/credential-providers": "^3.799.0",
    "@hono/node-server": "^1.19.5",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-aws-sdk": "^0.68.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@smithy/node-http-handler": "^4.4.5",
    "@stallion-ai/sdk": "^0.3.0",
    "@stallion-ai/shared": "^0.1.0",
    "@strands-agents/sdk": "^0.5.0",
    "@tanstack/react-query": "^5.90.12",
    "@tauri-apps/api": "^2.10.1",
    "@types/dompurify": "^3.0.5",
    "@voltagent/core": "^1.1.30",
    "@voltagent/libsql": "^1.0.9",
    "@voltagent/logger": "^1.0.3",
    "@voltagent/server-hono": "^1.0.22",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^5.0.76",
    "ajv": "^8.12.0",
    "chokidar": "^3.6.0",
    "debug": "^4.4.3",
    "dompurify": "^3.3.0",
    "dotenv": "^17.2.3",
    "hono": "^4.10.3",
    "node-pty": "^1.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.1",
    "ws": "^8.19.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@changesets/cli": "^2.29.0",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.9.1",
    "@testing-library/dom": "^10.4.1",
    "@types/debug": "^4.1.12",
    "@types/node": "^24.2.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@voltagent/cli": "^0.1.13",
    "@yao-pkg/pkg": "^6.9.0",
    "esbuild": "^0.25.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vitest": "^1.2.0",
    "wait-on": "^8.0.0"
  }
}
