{
  "uid": "stallion-overview",
  "title": "Stallion Overview",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Chat Requests",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(stallion_chat_requests_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Agents",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "targets": [
        {
          "expr": "stallion_agents_active",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "MCP Connections",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      },
      "targets": [
        {
          "expr": "stallion_mcp_connections",
          "legendFormat": "Connected"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Errors",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(stallion_chat_errors_total) or vector(0)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Chat Duration (p95)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(stallion_chat_duration_milliseconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Token Usage",
      "gridPos": {
        "x": 6,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(stallion_tokens_input_total)",
          "legendFormat": "Input"
        },
        {
          "expr": "sum(stallion_tokens_output_total)",
          "legendFormat": "Output"
        }
      ]
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Requests by Agent",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (agent) (stallion_chat_requests_total)",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests Over Time",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "rate(stallion_chat_requests_total[5m])",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Token Consumption Over Time",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "rate(stallion_tokens_input_total[5m])",
          "legendFormat": "Input"
        },
        {
          "expr": "rate(stallion_tokens_output_total[5m])",
          "legendFormat": "Output"
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Tool Calls",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (tool) (stallion_tool_calls_total)",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Tool Duration (p95)",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (tool, le) (rate(stallion_tool_duration_milliseconds_bucket[5m])))",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Context Overhead vs Input Tokens",
      "description": "Fixed context (system prompt + MCP tools) vs total input tokens per agent",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 15
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (agent) (stallion_tokens_context_total)",
          "legendFormat": "{{agent}} context"
        },
        {
          "expr": "sum by (agent) (stallion_tokens_input_total)",
          "legendFormat": "{{agent}} input"
        }
      ]
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Estimated Cost",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "fixed",
            "fixedColor": "yellow"
          },
          "decimals": 4
        }
      },
      "targets": [
        {
          "expr": "sum(stallion_cost_estimated_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 16,
      "type": "bargauge",
      "title": "Cost by Agent",
      "gridPos": {
        "x": 18,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "palette-classic"
          },
          "decimals": 4
        }
      },
      "targets": [
        {
          "expr": "sum by (agent) (stallion_cost_estimated_total)",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "custom": {
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "expr": "rate(stallion_chat_errors_total[5m])",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Chat Duration Distribution",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stallion-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (agent, le) (rate(stallion_chat_duration_milliseconds_bucket[5m])))",
          "legendFormat": "{{agent}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (agent, le) (rate(stallion_chat_duration_milliseconds_bucket[5m])))",
          "legendFormat": "{{agent}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (agent, le) (rate(stallion_chat_duration_milliseconds_bucket[5m])))",
          "legendFormat": "{{agent}} p99"
        }
      ]
    }
  ]
}