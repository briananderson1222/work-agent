{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default permissions for the application",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "mwinit",
          "cmd": "mwinit",
          "args": ["-f"],
          "sidecar": false
        }
      ]
    }
  ]
}
