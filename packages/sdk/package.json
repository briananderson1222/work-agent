{
  "name": "@stallion-ai/sdk",
  "version": "0.3.0",
  "description": "SDK for building Work Agent workspace plugins",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "node -e \"const fs=require('fs'),path=require('path');const src='src/components',dst='dist/components';fs.readdirSync(src).filter(f=>f.endsWith('.css')).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dst,f)))\"",
    "watch": "tsc --watch"
  },
  "keywords": ["work-agent", "plugin", "sdk"],
  "author": "Stallion AI",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.3.0"
  }
}
