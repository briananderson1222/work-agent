#!/bin/bash
set -e
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Bootstrap: ensure deps are installed
if [ ! -d "$SCRIPT_DIR/node_modules" ]; then
  echo "🐎 First run — installing dependencies..."
  npm install --prefix "$SCRIPT_DIR"
  echo "🐎 Installing Playwright browser bundle..."
  npm run --prefix "$SCRIPT_DIR" install:playwright
fi

# --link: register SDK and CLI as global npm links for plugin development
if [ "$1" = "--link" ]; then
  echo "🔗 Linking @stallion-ai/sdk and @stallion-ai/cli globally..."
  (cd "$SCRIPT_DIR/packages/sdk" && npm link)
  (cd "$SCRIPT_DIR/packages/cli" && npm link)
  echo ""
  echo "Done. In your plugin repo, run:"
  echo "  npm link @stallion-ai/sdk"
  echo "  npx @stallion-ai/cli dev"
  exit 0
fi

cd "$SCRIPT_DIR"
exec npx tsx "$SCRIPT_DIR/packages/cli/src/cli.ts" "$@"
